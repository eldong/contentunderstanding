# Azure AI Foundry endpoints
AZURE_AI_FOUNDRY_OPENAI_ENDPOINT=https://your-project.openai.azure.com/
AZURE_AI_FOUNDRY_SERVICES_ENDPOINT=https://your-project.services.ai.azure.com/

# Model deployments
AZURE_OPENAI_DEPLOYMENT=gpt-4o
