# Azure AI Foundry endpoints
AZURE_AI_FOUNDRY_OPENAI_ENDPOINT=https://your-project.openai.azure.com/
AZURE_AI_FOUNDRY_SERVICES_ENDPOINT=https://your-project.services.ai.azure.com/

# Model deployments
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# Authentication: uses DefaultAzureCredential (Azure CLI, managed identity, etc.)
# No API keys needed — run `az login` locally

# Azure Blob Storage for results (optional)
# Set both to enable uploading results to blob storage
# AZURE_STORAGE_ACCOUNT_URL=https://<your-account>.blob.core.windows.net
# AZURE_RESULTS_CONTAINER_NAME=validation-results
